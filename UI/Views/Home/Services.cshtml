@{
    ViewData["Title"] = ResourceTextHelper.L("Services", "Services");
}



<!-- Services Section Start -->
<section class="services-section section-padding">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <div class="section-title">
                    <h2>@(ResourceTextHelper.L("ServicesHeading", "What We Offer"))</h2>
                    <p>@(ResourceTextHelper.L("ServicesSubHeading", "Comprehensive shipping and logistics solutions tailored to your needs."))</p>
                </div>
            </div>
        </div>
        <div class="row">
            <!-- Service 1 -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card text-center p-4 border rounded h-100">
                    <div class="service-icon mb-3">
                        <i class="fas fa-shipping-fast fa-3x site-accent-icon"></i>
                    </div>
                    <h4>@(ResourceTextHelper.L("ServiceExpress", "Express Delivery"))</h4>
                    <p>@(ResourceTextHelper.L("ServiceExpressDesc", "Fast and reliable express shipping to get your packages delivered the same day or next day."))</p>
                </div>
            </div>
            <!-- Service 2 -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card text-center p-4 border rounded h-100">
                    <div class="service-icon mb-3">
                        <i class="fas fa-globe fa-3x site-accent-icon"></i>
                    </div>
                    <h4>@(ResourceTextHelper.L("ServiceInternational", "International Shipping"))</h4>
                    <p>@(ResourceTextHelper.L("ServiceInternationalDesc", "Global shipping services with full customs support and door-to-door delivery to over 50 countries."))</p>
                </div>
            </div>
            <!-- Service 3 -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card text-center p-4 border rounded h-100">
                    <div class="service-icon mb-3">
                        <i class="fas fa-warehouse fa-3x site-accent-icon"></i>
                    </div>
                    <h4>@(ResourceTextHelper.L("ServiceWarehouse", "Warehousing"))</h4>
                    <p>@(ResourceTextHelper.L("ServiceWarehouseDesc", "Secure short-term and long-term storage solutions with inventory management and order fulfillment."))</p>
                </div>
            </div>
            <!-- Service 4 -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card text-center p-4 border rounded h-100">
                    <div class="service-icon mb-3">
                        <i class="fas fa-map-marker-alt fa-3x site-accent-icon"></i>
                    </div>
                    <h4>@(ResourceTextHelper.L("ServiceTracking", "Real-Time Tracking"))</h4>
                    <p>@(ResourceTextHelper.L("ServiceTrackingDesc", "Track your shipments in real time with our advanced tracking system and instant notifications."))</p>
                </div>
            </div>
            <!-- Service 5 -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card text-center p-4 border rounded h-100">
                    <div class="service-icon mb-3">
                        <i class="fas fa-truck fa-3x site-accent-icon"></i>
                    </div>
                    <h4>@(ResourceTextHelper.L("ServiceFreight", "Freight Services"))</h4>
                    <p>@(ResourceTextHelper.L("ServiceFreightDesc", "Heavy and bulk cargo shipping by land, sea, or air with competitive rates and full insurance coverage."))</p>
                </div>
            </div>
            <!-- Service 6 -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="service-card text-center p-4 border rounded h-100">
                    <div class="service-icon mb-3">
                        <i class="fas fa-headset fa-3x site-accent-icon"></i>
                    </div>
                    <h4>@(ResourceTextHelper.L("ServiceSupport", "24/7 Support"))</h4>
                    <p>@(ResourceTextHelper.L("ServiceSupportDesc", "Our dedicated customer support team is available around the clock to assist you with any queries."))</p>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="row mt-4">
            <div class="col-12 text-center">
                <a asp-controller="Shipments" asp-action="Create" class="wshipping-button">
                    @(ResourceTextHelper.L("GetStarted", "Get Started"))
                </a>
            </div>
        </div>
    </div>
</section>
<!-- Services Section End -->
