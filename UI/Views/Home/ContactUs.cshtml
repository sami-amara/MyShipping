@{
    ViewData["Title"] = AppResource.Labels.Contact ?? "Contact Us";
}



<!-- Contact Section Start -->
<section class="contact-section section-padding">
    <div class="container">
        <div class="row">
            <!-- Contact Info -->
            <div class="col-lg-4 mb-5 mb-lg-0">
                <div class="contact-info">
                    <div class="section-title mb-4">
                        <h2>@(ResourceTextHelper.L("GetInTouch", "Get In Touch"))</h2>
                    </div>
                    <div class="contact-info-item d-flex mb-4">
                        <div class="contact-icon me-3">
                            <i class="fas fa-map-marker-alt fa-2x site-accent-icon"></i>
                        </div>
                        <div>
                            <h5>@(ResourceTextHelper.L("OurAddress", "Our Address"))</h5>
                            <p>@(ResourceTextHelper.L("AddressValue", "123 Shipping Street, Logistics City"))</p>
                        </div>
                    </div>
                    <div class="contact-info-item d-flex mb-4">
                        <div class="contact-icon me-3">
                            <i class="fas fa-phone fa-2x site-accent-icon"></i>
                        </div>
                        <div>
                            <h5>@(ResourceTextHelper.L("PhoneNumber", "Phone Number"))</h5>
                            <p>@(ResourceTextHelper.L("ContactPhoneValue", "+88 01xxx 8xxx04"))</p>
                        </div>
                    </div>
                    <div class="contact-info-item d-flex mb-4">
                        <div class="contact-icon me-3">
                            <i class="fas fa-envelope fa-2x site-accent-icon"></i>
                        </div>
                        <div>
                            <h5>@(ResourceTextHelper.L("EmailAddress", "Email Address"))</h5>
                            <p>@(ResourceTextHelper.L("ContactEmailValue", "info@@company.com"))</p>
                        </div>
                    </div>
                    <div class="contact-info-item d-flex mb-4">
                        <div class="contact-icon me-3">
                            <i class="far fa-clock fa-2x site-accent-icon"></i>
                        </div>
                        <div>
                            <h5>@(ResourceTextHelper.L("BusinessHoursLabel", "Business Hours"))</h5>
                            <p>@(ResourceTextHelper.L("BusinessHours", "9:00AM to 8:00PM"))</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-8">
                <div class="contact-form-wrapper">
                    <div class="section-title mb-4">
                        <h2>@(ResourceTextHelper.L("SendUsMessage", "Send Us a Message"))</h2>
                    </div>
                    <form id="contactForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">@(ResourceTextHelper.L("FullName", "Full Name"))</label>
                                <input type="text" class="form-control" placeholder="@(ResourceTextHelper.L("FullName", "Full Name"))" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">@(ResourceTextHelper.L("EmailAddress", "Email Address"))</label>
                                <input type="email" class="form-control" placeholder="@(ResourceTextHelper.L("EmailAddress", "Email Address"))" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@(ResourceTextHelper.L("Subject", "Subject"))</label>
                            <input type="text" class="form-control" placeholder="@(ResourceTextHelper.L("Subject", "Subject"))" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@(ResourceTextHelper.L("Message", "Message"))</label>
                            <textarea class="form-control" rows="6" placeholder="@(ResourceTextHelper.L("WriteYourMessage", "Write your message here..."))" required></textarea>
                        </div>
                        <button type="submit" class="wshipping-button">
                            @(ResourceTextHelper.L("SendMessage", "Send Message"))
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Contact Section End -->
