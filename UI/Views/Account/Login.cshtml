


@using Business.DTOS;
@model LoginDto

@{
    ViewData["Title"] = "Login";
    var rateLimitExceeded = TempData["RateLimitExceeded"] as bool? ?? false;
    var retryAfterSeconds = TempData["RetryAfterSeconds"] as int? ?? 900;
    var retryAfterMinutes = TempData["RetryAfterMinutes"] as int? ?? 15;
}

<div class="wshipping-content-block">
    <div class="container">
        <div class="customer-login">
            <div class="row">
                <div class="col-12 col-md-6 col-lg-6">
                    <div class="customer-login-left">
                        <div class="login-icon"><i class="fa fa-lock"></i></div>
                        <h4>Welcome To your account</h4>
                        <p>Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p>
                        <a asp-controller="Account" asp-action="Register">Create A new Account</a>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-6">
                    <div class="customer-login-block">
                        <h2>Login To Your Account</h2>
                        
                     
                        @if (rateLimitExceeded)
                        {
                            <div class="alert alert-danger mt-3" role="alert" id="rateLimitAlert">
                                <i class="fa fa-exclamation-triangle"></i>
                                <strong>Too Many Login Attempts!</strong><br />
                                You've made too many login attempts. Please wait
                                <strong><span id="countdown">@retryAfterMinutes</span> minutes</strong>
                                before trying again.
                                <!-- Progress bar -->
                                <div class="progress mt-2 rate-limit-progress-login">
                                    <div class="progress-bar bg-danger" 
                                    id="rateLimitProgress"
                                         role="progressbar" 
                                         aria-valuenow="0" 
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>

                                <br />

                                <small class="text-muted">
                                    <i class="fa fa-shield-alt"></i> This security measure protects your account.
                                    (Time remaining: <strong id="timeRemaining">@retryAfterMinutes min</strong>)
                                </small>
                            </div>
                        }
                        
                        
                        @if (ViewData["LockoutEnd"] != null)
                        {
                            <div class="alert alert-danger mt-3" role="alert">
                                <i class="fa fa-lock"></i>
                                <strong>Account Locked!</strong><br />
                                Your account has been locked until <strong>@ViewData["LockoutEnd"]</strong>
                                due to multiple failed login attempts.
                            </div>
                        }
                        
                        <form asp-controller="Account" asp-action="Login" id="loginForm" method="post" role="form" class="pt-5" novalidate autocomplete="off">
                            <div class="form-group">
                                <label for="Input_Email">Email</label>
                                <input type="email" asp-for="Email" autocomplete="off"
                                       class="form-control form-control-lg" id="Input_Email" placeholder="Email">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label for="Input_Password">Password</label>
                                    <input type="password" asp-for="Password" autocomplete="off"
                                           class="form-control form-control-lg" id="Input_Password" placeholder="Password">
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>

                                    <div class="checkbox">
                                        <input asp-for="RememberMe" type="checkbox" name="rememberMe" id="rememberMe" class="css-checkbox" />
                                        <label for="rememberMe" class="css-label">Remember me</label>
                                        <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-pass">Forgot your password?</a>
                                    </div>
                                    <button type="submit" class="btn btn-submit">Login</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @await Html.PartialAsync("_AlertMessage")
        <partial name="_ValidationScriptsPartial" />

        @section Scripts {
            <div id="auth-form-config"
                 data-form-selector="#loginForm"
                 data-rule-key="loginForm"
                 data-rate-limit-exceeded="@(rateLimitExceeded.ToString().ToLower())"
                 data-retry-after-seconds="@retryAfterSeconds"></div>
            <script src="~/js/account-auth-forms.js" asp-append-version="true"></script>
        }












