@using Business.DTOS;
@model UserDto

@{
    ViewData["Title"] = "Register";
    var rateLimitExceeded = TempData["RateLimitExceeded"] as bool? ?? false;
    var retryAfterSeconds = TempData["RetryAfterSeconds"] as int? ?? 900;
    var retryAfterMinutes = TempData["RetryAfterMinutes"] as int? ?? 15;
}

<!-- Customer Registration Start -->
<div class="wshipping-content-block">
    <div class="container">
        <div class="customer-login">
            <div class="row">
                <div class="col-12 col-md-6 col-lg-6">
                    <div class="customer-login-left">
                        <div class="login-icon"><i class="fa fa-unlock-alt"></i></div>
                        <h4>Welcome To new account</h4>
                        <p>Lorem Ipsum is simply dummy text of the printing and typesetting industry.</p>
                        <a asp-controller="Account" asp-action="Login">If you have account already, please login in</a>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-6">
                    <div class="customer-login-block">
                        <h2>Registration</h2>
                        
                        @* ✅ RATE LIMIT ALERT *@
                        @if (rateLimitExceeded)
                        {
                            <div class="alert alert-danger mt-3" role="alert" id="rateLimitAlert">
                                <i class="fa fa-exclamation-triangle"></i>
                                <strong>Too Many Registration Attempts!</strong><br />
                                You've made too many registration attempts. Please wait
                                <strong><span id="countdown">@retryAfterMinutes</span> minutes</strong>
                                before trying again.
                                <div class="mb-2">
                                    <div class="progress rate-limit-progress-register">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-danger"
                                             id="rateLimitProgress"
                                             role="progressbar"
                                             aria-valuenow="0"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                        </div>
                                    </div>
                                </div>
                                <br />
                                <small class="text-muted">
                                    <i class="fa fa-shield-alt"></i> This security measure prevents spam and abuse.
                                    (Time remaining: <strong id="timeRemaining">@retryAfterMinutes min</strong>)
                                </small>
                            </div>
                            
                        }
                        
                        @* ✅ SUCCESS MESSAGE *@
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success mt-3" role="alert">
                                <i class="fa fa-check-circle"></i>
                                <strong>Success!</strong><br />
                                @TempData["SuccessMessage"]
                            </div>
                        }
                        
                        @* ✅ VALIDATION ERRORS *@
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger mt-3" role="alert">
                                <i class="fa fa-exclamation-circle"></i>
                                <strong>Please fix the following errors:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
                        
                        <form asp-controller="Account" asp-action="Register" method="post" role="form" class="pt-5" id="registerForm" novalidate>
                            <div class="form-group">
                                <div class="row">
                                    <div class="col-12 col-md-6 col-lg-6">
                                        <label>First Name:</label>
                                        <input asp-for="FirstName" type="text" class="form-control" />
                                        <span asp-validation-for="FirstName" class="text-danger"></span>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-6">
                                        <label>Last Name:</label>
                                        <input asp-for="LastName" type="text" class="form-control" />
                                        <span asp-validation-for="LastName" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="row">
                                    <div class="col-12 col-md-6 col-lg-6">
                                        <label>Email:</label>
                                        <input asp-for="Email" type="text" class="form-control" />
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-6">
                                        <label>Phone:</label>
                                        <input asp-for="Phone" type="text" class="form-control" />
                                        <span asp-validation-for="Phone" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <div class="row">
                                    <div class="col-12 col-md-6 col-lg-6">
                                        <label>Password:</label>
                                        <input asp-for="Password" type="password" class="form-control" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <div class="col-12 col-md-6 col-lg-6">
                                        <label>Confirm Password:</label>
                                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-submit">Registration</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />

@section Scripts {
    <div id="auth-form-config"
         data-form-selector="#registerForm"
         data-rule-key="registerForm"
         data-rate-limit-exceeded="@(rateLimitExceeded.ToString().ToLower())"
         data-retry-after-seconds="@retryAfterSeconds"></div>
    <script src="~/js/account-auth-forms.js" asp-append-version="true"></script>
}



