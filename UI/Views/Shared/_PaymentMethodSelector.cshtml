@model Guid


@{
    // Get shipment details for payment amount display
    var shipmentId = Model;
}

<!-- Payment Method Selector Modal -->
<div class="modal fade" id="paymentMethodModal" tabindex="-1" aria-labelledby="paymentMethodModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="paymentMethodModalLabel">
                    <i class="mdi mdi-credit-card"></i>
                    Select Payment Method
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-center text-muted mb-4">
                    <i class="mdi mdi-information-outline"></i>
                    Choose your preferred payment method to complete the transaction
                </p>

                <div class="row g-3">
                    @* PayPal Option *@
                    <div class="col-md-6">
                        <button class="payment-method-card w-100 h-100"
                                type="button"
                                data-payment-method="paypal"
                                data-shipment-id="@shipmentId">
                            <div class="text-center p-4">
                                <i class="mdi mdi-paypal payment-method-paypal-icon"></i>
                                <h6 class="mt-3 mb-2">PayPal</h6>
                                <p class="text-muted small mb-0">
                                    Fast & secure payment with PayPal account or card
                                </p>
                            </div>
                        </button>
                    </div>

                    @* Stripe Option *@
                    <div class="col-md-6">
                        <button class="payment-method-card w-100 h-100"
                                type="button"
                                data-payment-method="stripe"
                                data-shipment-id="@shipmentId">
                            <div class="text-center p-4">
                                <i class="mdi mdi-credit-card-outline payment-method-stripe-icon"></i>
                                <h6 class="mt-3 mb-2">Credit Card</h6>
                                <p class="text-muted small mb-0">
                                    Secure payment via Stripe (Visa, Mastercard, Amex)
                                </p>
                            </div>
                        </button>
                    </div>
                </div>

                <div class="mt-4 text-center">
                    <small class="text-muted">
                        <i class="mdi mdi-lock-outline"></i>
                        All payments are secure and encrypted
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
