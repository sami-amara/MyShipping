{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es2015", "dom"],
    "module": "esnext",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "wwwroot/**/*.js",
    "wwwroot/**/*.ts",
    "./**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "wwwroot/**/node_modules"
  ]
}
