@{
    Layout = "~/Areas/admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Labels.PaymentTransactionDetails;
    var transaction = ViewBag.Transaction as Business.DTOS.PaymentTransactionDto;
    var canRefund = ViewBag.CanRefund as bool? ?? false;
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">
            <span class="page-title-icon bg-gradient-primary text-white me-2">
                <i class="mdi mdi-receipt"></i>
            </span> @Labels.PaymentReceipt
        </h3>
        <nav aria-label="breadcrumb">
            <ul class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-action="Index">@Labels.PaymentTransactions</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    <span></span>@Labels.Details
                </li>
            </ul>
        </nav>
    </div>

    @if (transaction != null)
    {
        <div class="row">
            <div class="col-12 grid-margin">
                <div class="card">
                    <div class="card-body">
                        <!-- Transaction Header -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h4 class="card-title mb-2">@Labels.TransactionDetails</h4>
                                <p class="text-muted mb-0">@Labels.ID <code>@transaction.Id</code></p>
                            </div>
                            <div>
                                @{
                                    var statusColor = PaymentTransactionLocalizationHelper.GetStatusColor(transaction.TransactionStatusName);
                                    var localizedStatus = PaymentTransactionLocalizationHelper.GetLocalizedStatus(transaction.TransactionStatus, transaction.TransactionStatusName);
                                    var localizedPaymentMethod = PaymentTransactionLocalizationHelper.GetLocalizedPaymentMethod(transaction.PaymentMethodName);
                                }
                                <label class="badge badge-@statusColor badge-pill px-3 py-2 payment-transaction-status-badge">
                                    @localizedStatus
                                </label>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Transaction Information -->
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">
                                            <i class="mdi mdi-information"></i> @Labels.TransactionInformation
                                        </h5>
                                        <table class="table table-borderless mb-0">
                                            <tr>
                                                <td class="font-weight-bold">@Labels.DateTime:</td>
                                                <td>@((transaction.ProcessedDate ?? transaction.CreatedDate).ToString("MMMM dd, yyyy HH:mm:ss"))</td>
                                            </tr>
                                            <tr>
                                                <td class="font-weight-bold">@Labels.PaymentMethod:</td>
                                                <td>@localizedPaymentMethod</td>
                                            </tr>
                                            @if (!string.IsNullOrEmpty(transaction.TransactionReference))
                                            {
                                                <tr>
                                                    <td class="font-weight-bold">@Labels.Reference:</td>
                                                    <td><code>@transaction.TransactionReference</code></td>
                                                </tr>
                                            }
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Shipment Information -->
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">
                                            <i class="mdi mdi-package-variant"></i> @Labels.ShipmentInformation
                                        </h5>
                                        <table class="table table-borderless mb-0">
                                            <tr>
                                                <td class="font-weight-bold">@Labels.TrackingNumber:</td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(transaction.ShipmentTrackingNumber))
                                                    {
                                                        <span class="badge badge-info">@transaction.ShipmentTrackingNumber</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">@ResourceTextHelper.L("NotAvailable", "N/A")</span>
                                                    }
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="font-weight-bold">@Labels.ShipmentID:</td>
                                                <td><small class="text-muted">@transaction.ShipmentId.ToString("N").Substring(0, 13)...</small></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Payment Breakdown -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="card border-primary">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary">
                                            <i class="mdi mdi-calculator"></i> @Labels.PaymentBreakdown
                                        </h5>
                                        <table class="table">
                                            <tr>
                                                <td class="font-weight-bold">@Labels.ShippingRate</td>
                                                <td class="text-right">@transaction.ShippingRate.ToString("C")</td>
                                            </tr>
                                            <tr>
                                                <td class="font-weight-bold">
                                                    @Labels.Commission (@transaction.CommissionPercentage.ToString("F2")%)
                                                </td>
                                                <td class="text-right">@transaction.CommissionAmount.ToString("C")</td>
                                            </tr>
                                            <tr class="table-active">
                                                <td class="font-weight-bold h5 mb-0">@Labels.TotalAmount</td>
                                                <td class="text-right font-weight-bold h4 text-primary mb-0">
                                                    @transaction.TotalAmount.ToString("C")
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Notes -->
                        @if (!string.IsNullOrEmpty(transaction.Notes))
                        {
                            <div class="row mt-4">
                                <div class="col-md-12">
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <i class="mdi mdi-note-text"></i> @Labels.Notes
                                            </h5>
                                            <p class="mb-0 payment-transaction-notes">@transaction.Notes</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Error Message -->
                        @if (!string.IsNullOrEmpty(transaction.ErrorMessage))
                        {
                            <div class="row mt-4">
                                <div class="col-md-12">
                                    <div class="alert alert-danger">
                                        <h5><i class="mdi mdi-alert"></i> @Labels.Error</h5>
                                        <p class="mb-0">@transaction.ErrorMessage</p>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Action Buttons -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="mdi mdi-arrow-left"></i> @Labels.BackToList
                                    </a>

                                    @if (canRefund)
                                    {
                                        <button type="button" class="btn btn-gradient-danger" id="openRefundModal">
                                            <i class="mdi mdi-cash-refund"></i> @Labels.ProcessRefund
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Educational Note -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="alert alert-warning">
                                    <h6><i class="mdi mdi-school"></i> @Labels.EducationalSystem</h6>
                                    <p class="mb-0">@Labels.EducationalPaymentDisclaimer</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Refund Modal -->
        @if (canRefund)
        {
            <div class="modal fade" id="refundModal" tabindex="-1" role="dialog" aria-labelledby="refundModalLabel" aria-hidden="true">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <form asp-action="ProcessRefund" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@transaction.Id" />

                            <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title" id="refundModalLabel">
                                    <i class="mdi mdi-cash-refund"></i> @Labels.ProcessRefund
                                </h5>
                                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="alert alert-warning">
                                    <strong>@Labels.Warning:</strong> @Labels.RefundWarning
                                </div>

                                <div class="form-group">
                                    <label for="reason" class="font-weight-bold">@Labels.RefundReason <span class="text-danger">@Labels.Required</span></label>
                                    <textarea class="form-control" id="reason" name="reason" rows="3" required
                                              placeholder="@Labels.RefundReasonPlaceholder"></textarea>
                                </div>

                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6 class="card-title">@Labels.TransactionSummary</h6>
                                        <p class="mb-1"><strong>@Labels.Amount:</strong> @transaction.TotalAmount.ToString("C")</p>
                                        <p class="mb-0"><strong>@Labels.PaymentMethod:</strong> @localizedPaymentMethod</p>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-dismiss="modal">@Labels.Cancel</button>
                                <button type="submit" class="btn btn-danger">
                                    <i class="mdi mdi-cash-refund"></i> @Labels.ConfirmRefund
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="mdi mdi-alert-circle-outline payment-transaction-missing-icon"></i>
                        <h3 class="mt-3">@Labels.TransactionNotFound</h3>
                        <p class="text-muted">@Labels.TransactionNotFoundMessage</p>
                        <a asp-action="Index" class="btn btn-gradient-primary mt-3">
                            <i class="mdi mdi-arrow-left"></i> @Labels.ReturnToPaymentTransactions
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @if (TempData["MessageType"] != null && TempData["Message"] != null)
    {
        <div id="payment-transaction-alert-config" data-message-type="@TempData["MessageType"]"></div>
        <textarea id="payment-transaction-alert-message" class="d-none">@Html.Raw(Json.Serialize(TempData["Message"].ToString()))</textarea>
    }
    <script src="~/Admin/assets/js/payment-transaction-details.js" asp-append-version="true"></script>
}
