@{
    Layout = "~/Areas/admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Labels.PaymentTransactions;
    var transactions = ViewBag.Transactions as DataAccessLayer.Model.PagedResult<Business.DTOS.PaymentTransactionDto>;
    var pager = ViewBag.Pager as UI.Models.PaginationInfo;
    var paymentMethods = ViewBag.PaymentMethods as List<Business.DTOS.PaymentMethodDto> ?? new List<Business.DTOS.PaymentMethodDto>();
    var currentStatus = ViewBag.CurrentStatus as int?;
    var currentPaymentMethod = ViewBag.CurrentPaymentMethod as Guid?;
    var currentSearch = ViewBag.CurrentSearch as string;
    var currentStartDate = ViewBag.CurrentStartDate as string;
    var currentEndDate = ViewBag.CurrentEndDate as string;
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">
            <span class="page-title-icon bg-gradient-primary text-white me-2">
                <i class="mdi mdi-credit-card"></i>
            </span> @ViewData["Title"]
        </h3>
        <nav aria-label="breadcrumb">
            <ul class="breadcrumb">
                <li class="breadcrumb-item active" aria-current="page">
                    <span></span>@Labels.Management
                </li>
            </ul>
        </nav>
    </div>

    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">@Labels.AllPaymentTransactions</h4>

                    @* Filter Form *@
                    <form asp-action="Index" asp-controller="PaymentTransactions" asp-area="admin" method="get" class="mb-3">
                        <div class="row g-2 align-items-end">
                            <!-- Search -->
                            <div class="col-md-3">
                                <input type="text" name="search" class="form-control form-control-lg" 
                                       placeholder="@Labels.SearchByTrackingNumber"
                                       value="@currentSearch" />
                            </div>

                            <!-- Status Filter -->
                            <div class="col-md-2">
                                <select name="status" class="form-select form-select-lg">
                                    <option value="">@Labels.AllStatuses</option>
                                    <option value="0" selected="@(currentStatus == 0)">@Labels.Pending</option>
                                    <option value="1" selected="@(currentStatus == 1)">@Labels.Completed</option>
                                    <option value="2" selected="@(currentStatus == 2)">@Labels.Failed</option>
                                    <option value="3" selected="@(currentStatus == 3)">@Labels.Refunded</option>
                                </select>
                            </div>

                            <!-- Payment Method Filter -->
                            <div class="col-md-2">
                                <select name="paymentMethodId" class="form-select form-select-lg">
                                    <option value="">@Labels.AllMethods</option>
                                    @foreach (var method in paymentMethods)
                                    {
                                        <option value="@method.Id" selected="@(currentPaymentMethod == method.Id)">
                                            @method.MethodEname
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Date Range -->
                            <div class="col-md-4">
                                <div class="input-group input-group-lg">
                                    <input type="date" name="startDate" class="form-control" 
                                           value="@currentStartDate" placeholder="@Labels.StartDate" title="@Labels.StartDate" />
                                    <span class="input-group-text">@Labels.To</span>
                                    <input type="date" name="endDate" class="form-control" 
                                           value="@currentEndDate" placeholder="@Labels.EndDate" title="@Labels.EndDate" />
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="col-md-1">
                                <button type="submit" class="btn btn-gradient-primary btn-lg w-100">
                                    <i class="mdi mdi-magnify"></i>
                                </button>
                            </div>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>@Labels.TransactionID</th>
                                    <th>@Labels.DateTime</th>
                                    <th>@Labels.TrackingNumber</th>
                                    <th>@Labels.PaymentMethod</th>
                                    <th>@Labels.Amount</th>
                                    <th>@Labels.Status</th>
                                    <th>@Labels.Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transactions?.Items?.Any() == true)
                                {
                                    int counter = (pager.Page - 1) * pager.PageSize + 1;
                                    foreach (var transaction in transactions.Items)
                                    {
                                        var statusColor = PaymentTransactionLocalizationHelper.GetStatusColor(transaction.TransactionStatusName);
                                        var localizedStatus = PaymentTransactionLocalizationHelper.GetLocalizedStatus(transaction.TransactionStatus, transaction.TransactionStatusName);
                                        var localizedPaymentMethod = PaymentTransactionLocalizationHelper.GetLocalizedPaymentMethod(transaction.PaymentMethodName);

                                        <tr>
                                            <td>@counter</td>
                                            <td>
                                                <small class="text-muted">@transaction.Id.ToString("N").Substring(0, 13)...</small>
                                            </td>
                                            <td>@transaction.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(transaction.ShipmentTrackingNumber))
                                                {
                                                    <span class="badge badge-info">@transaction.ShipmentTrackingNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@localizedPaymentMethod</td>
                                            <td class="font-weight-bold text-primary">@transaction.TotalAmount.ToString("C")</td>
                                            <td>
                                                <label class="badge badge-@statusColor">
                                                    @localizedStatus
                                                </label>
                                            </td>
                                            <td>
                                                <a asp-action="Details" asp-route-id="@transaction.Id" 
                                                   class="btn btn-sm btn-gradient-info" title="@(ResourceTextHelper.L("ViewDetails", "View Details"))">
                                                    <i class="mdi mdi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        counter++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center">@Labels.NoTransactionsFound</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* Pagination *@
                    @if (pager != null && pager.TotalPages > 1)
                    {
                        <nav aria-label="Pagination" class="mt-3">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(pager.HasPrevious ? "" : "disabled")">
                                    <a class="page-link" 
                                       href="@Url.Action("Index", new { 
                                           page = pager.PrevPage, 
                                           status = currentStatus, 
                                           paymentMethodId = currentPaymentMethod, 
                                           search = currentSearch,
                                           startDate = currentStartDate,
                                           endDate = currentEndDate
                                       })">
                                        &laquo; @Labels.Previous
                                    </a>
                                </li>

                                @for (int p = pager.Start; p <= pager.End; p++)
                                {
                                    if (p == pager.Page)
                                    {
                                        <li class="page-item active"><span class="page-link">@p</span></li>
                                    }
                                    else
                                    {
                                        <li class="page-item">
                                            <a class="page-link" 
                                               href="@Url.Action("Index", new { 
                                                   page = p, 
                                                   status = currentStatus, 
                                                   paymentMethodId = currentPaymentMethod, 
                                                   search = currentSearch,
                                                   startDate = currentStartDate,
                                                   endDate = currentEndDate
                                               })">
                                                @p
                                            </a>
                                        </li>
                                    }
                                }

                                <li class="page-item @(pager.HasNext ? "" : "disabled")">
                                    <a class="page-link" 
                                       href="@Url.Action("Index", new { 
                                           page = pager.NextPage, 
                                           status = currentStatus, 
                                           paymentMethodId = currentPaymentMethod, 
                                           search = currentSearch,
                                           startDate = currentStartDate,
                                           endDate = currentEndDate
                                       })">
                                        @Labels.Next &raquo;
                                    </a>
                                </li>
                            </ul>

                            <div class="text-center mt-2">
                                <small class="text-muted">@Labels.Page @pager.Page @Labels.Of @pager.TotalPages — @Labels.Showing @transactions.Items.Count @Labels.Of @transactions.TotalCount</small>
                            </div>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
