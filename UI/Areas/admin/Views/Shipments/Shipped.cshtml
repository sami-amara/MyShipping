@using Business.DTOS
@using Business.Services.Shipment
@model Business.DTOS.ShippmentDto

@{
    Layout = "~/Areas/admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = (AppResource.Labels.MarkShipped ?? "Mark Shipment as Shipped");
    var currentState = Model?.CurrentState ?? 0;
    var statuses = Enum.GetValues(typeof(ShipmentStatusEnum)).Cast<ShipmentStatusEnum>().ToList();
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">@ViewData["Title"]</h3>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h4 class="card-title mb-0">@ViewData["Title"]</h4>

                @* Payment Status Badge *@
                <div>
                    @if (Model?.IsPaid ?? false)
                    {
                        <span class="badge bg-success">
                            <i class="mdi mdi-check-circle"></i>
                            <span>@(AppResource.Labels.Active ?? "Paid")</span>
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="mdi mdi-alert-circle"></i>
                            <span>@(AppResource.Labels.UnPaid ?? "Unpaid")</span>
                        </span>
                    }
                </div>
            </div>

            @* Warning message if unpaid *@
            @if (!(Model?.IsPaid ?? false))
            {
                <div class="alert alert-warning" role="alert">
                    <i class="mdi mdi-alert-circle"></i>
                    <strong>Warning:</strong> This shipment is not paid. Payment is required before shipping.
                </div>
            }

            <!-- Progress / status steps -->
            <ul class="nav nav-pills mb-4">
                @foreach (var st in statuses)
                {
                    var intVal = (int)st;
                    var isCompleted = currentState > intVal;
                    var isActive = currentState == intVal;
                    var cls = isActive ? "btn btn-sm btn-gradient-info me-2" : (isCompleted ? "btn btn-sm btn-gradient-success me-2" : "btn btn-sm btn-outline-secondary me-2");
                    <li class="nav-item"><span class="@cls" data-status-value="@intVal">@st.ToString()</span></li>
                }
            </ul>

            <form id="shippedForm" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />
              @*   <input type="hidden" name="PaymentMethodId" value="@Model.PaymentMethodId" />
                <input type="hidden" name="IsPaid" value="@Model.IsPaid" /> *@

                <div class="mb-3">
                    <label class="form-label">Shipment Details</label>
                    <dl class="row">
                        <dt class="col-sm-3">Tracking Number</dt>
                        <dd class="col-sm-9">@Model.TrackingNumber</dd>
                        
                        <dt class="col-sm-3">Sender</dt>
                        <dd class="col-sm-9">@Model.UserSender?.SenderName</dd>
                        
                        <dt class="col-sm-3">Receiver</dt>
                        <dd class="col-sm-9">@Model.UserReceiver?.ReceiverName</dd>
                        
                        <dt class="col-sm-3">Current Status</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info">@((ShipmentStatusEnum)Model.CurrentState)</span>
                        </dd>
                    </dl>
                </div>

                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    Clicking "Mark as Shipped" will record the current date and time as the delivery date.
                </div>

                <div class="d-flex">
                                                              
                    <button id="btnMarkShipped" type="button" class="btn btn-gradient-primary me-2"
                            data-target-state="5">
                        <i class="fas fa-shipping-fast"></i> @(AppResource.Labels.MarkShipped)
                    </button>
                    <a asp-action="List" class="btn btn-outline-secondary">@AppResource.Labels.Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Modules/AppHelper.js"></script>
    <script src="~/Modules/ApiClient.js"></script>
    <script src="~/Modules/ShipmentApiClient.js"></script>
    <script src="~/Modules/ShipmentService.js"></script>



    @* Shipped.js kept for backwards compatibility — UpdateStatus.js handles the generic route *@
  @*   <script src="~/Modules/Shipped.js"></script> *@



    @*   Using Generic ChangeStatus endpoint to update shipment status from Readyforshipped to Shipped *@
    <script src="~/Modules/UpdateStatus.js"></script>




}

