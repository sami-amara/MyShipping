@using Business.DTOS
@using Business.Services.Shipment
@model Business.DTOS.ShippmentDto

@{
    Layout = "~/Areas/admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = AppResource.Labels.CancelShipment ?? "Cancel Shipment";
    var currentState = Model?.CurrentState ?? 0;
    var statuses = Enum.GetValues(typeof(ShipmentStatusEnum)).Cast<ShipmentStatusEnum>().ToList();
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">@ViewData["Title"]</h3>
    </div>

    <div class="card">
        <div class="card-body">
            <h4 class="card-title">@ViewData["Title"]</h4>

            <ul class="nav nav-pills mb-4">
                @foreach (var st in statuses)
                {
                    var intVal = (int)st;
                    var isCompleted = currentState > intVal;
                    var isActive = currentState == intVal;
                    var cls = isActive ? "btn btn-sm btn-gradient-info me-2" : (isCompleted ? "btn btn-sm btn-gradient-success me-2" : "btn btn-sm btn-outline-secondary me-2");
                    <li class="nav-item"><span class="@cls" data-status-value="@intVal">@st.ToString()</span></li>
                }
            </ul>

            <form id="refundForm" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" id="shipmentId" value="@Model.Id" />
                <input type="hidden" id="listUrl" value="@Url.Action("List", "Shipments", new { area = "admin", refunded = 1, refundedId = Model.Id })" />

                <div class="mb-3">
                    <label class="form-label">@(AppResource.Labels.ShipmentDetails ?? "Shipment Details")</label>
                    <dl class="row">
                        <dt class="col-sm-3">@(AppResource.Labels.TrackingNumber ?? "Tracking Number")</dt>
                        <dd class="col-sm-9">@Model.TrackingNumber</dd>

                        <dt class="col-sm-3">@(AppResource.Labels.Sender ?? "Sender")</dt>
                        <dd class="col-sm-9">@Model.UserSender?.SenderName</dd>

                        <dt class="col-sm-3">@(AppResource.Labels.Receiver ?? "Receiver")</dt>
                        <dd class="col-sm-9">@Model.UserReceiver?.ReceiverName</dd>

                        <dt class="col-sm-3">@(AppResource.Labels.CurrentStatus ?? "Current Status")</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-warning">@((ShipmentStatusEnum)Model.CurrentState)</span>
                        </dd>

                        <dt class="col-sm-3">@(AppResource.Labels.PaymentStatus ?? "Payment Status")</dt>
                        <dd class="col-sm-9">
                            <span class="badge @(Model.IsPaid ? "bg-success" : "bg-secondary")">
                                @(Model.IsPaid ? (AppResource.Labels.Paid ?? "Paid") : (AppResource.Labels.UnPaid ?? "Unpaid"))
                            </span>
                        </dd>
                    </dl>
                </div>

                <div class="mb-3">
                    <label for="reason" class="form-label">@(AppResource.Labels.CancellationReason ?? "Cancellation Reason")</label>
                    <textarea id="reason" name="reason" class="form-control" rows="3" required
                              placeholder="@(AppResource.Labels.CancellationReasonPlaceholder ?? "Enter the reason for cancelling this shipment")"></textarea>
                </div>

                <div class="alert alert-danger">
                    <i class="fas fa-undo-alt"></i>
                    @(AppResource.Labels.CancelShipmentWarning ?? "Clicking \"Cancel Shipment\" will complete the cancellation, issue a full PayPal refund, and mark this shipment as Refunded. This action cannot be undone.")
                </div>

                <div class="d-flex">
                    <button id="btnRefundPayment" type="button" class="btn btn-gradient-danger me-2">
                        <i class="fas fa-undo-alt"></i> @(AppResource.Labels.CancelShipmentButton ?? "Cancel Shipment")
                    </button>
                    <a asp-action="Show" asp-route-id="@Model.Id" class="btn btn-outline-secondary">@(AppResource.Labels.Back ?? "Back")</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Modules/ApiClient.js" asp-append-version="true"></script>
    <script src="~/Modules/RefundShipmentPayment.js" asp-append-version="true"></script>
}