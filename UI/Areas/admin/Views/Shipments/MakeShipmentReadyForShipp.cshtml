@using Business.DTOS
@using Business.Services.Shipment
@model Business.DTOS.ShippmentDto


<!-- ✅ Phase 5 Defaults - Hidden JSON for JavaScript -->
<textarea id="shipment-defaults-json" class="d-none">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
{
    defaultCarrierId = ViewData["DefaultCarrierId"]?.ToString() ?? "",

}))</textarea>

@{
    Layout = "~/Areas/admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = (AppResource.Labels.MarkReadyForShipping ?? "Mark Shipment Ready for Shipping");
    var currentState = Model?.CurrentState ?? 0;
    var statuses = Enum.GetValues(typeof(ShipmentStatusEnum)).Cast<ShipmentStatusEnum>().ToList();
}
<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title">@ViewData["Title"]</h3>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h4 class="card-title mb-0">@ViewData["Title"]</h4>

                @* Payment Status Badge *@
                <div>
                    @if (Model?.IsPaid ?? false)
                    {
                        <span class="badge bg-success">
                            <i class="mdi mdi-check-circle"></i>
                            <span>@(AppResource.Labels.Active ?? "Paid")</span>
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="mdi mdi-alert-circle"></i>
                            <span>@(AppResource.Labels.UnPaid ?? "Unpaid")</span>
                        </span>
                    }
                </div>
            </div>

            @* Warning message if unpaid *@
            @if (!(Model?.IsPaid ?? false))
            {
                <div class="alert alert-warning" role="alert">
                    <i class="mdi mdi-alert-circle"></i>
                    <strong>Warning:</strong> This shipment is not paid. Payment is required before marking it ready for shipping.
                </div>
            }

            <!-- Progress / status steps (uses ShipmentStatusEnum) -->
            <ul class="nav nav-pills mb-4">
                @foreach (var st in statuses)
                {
                    var intVal = (int)st;
                    var isCompleted = currentState > intVal;
                    var isActive = currentState == intVal;
                    var cls = isActive ? "btn btn-sm btn-gradient-info me-2" : (isCompleted ? "btn btn-sm btn-gradient-success me-2" : "btn btn-sm btn-outline-secondary me-2");
                    <li class="nav-item"><span class="@cls" data-status-value="@intVal">@st.ToString()</span></li>
                }
            </ul>

            <form id="makeReadyForm" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />
               @*  <input type="hidden" name="PaymentMethodId" value="@Model.PaymentMethodId" />
                <input type="hidden" name="IsPaid" value="@Model.IsPaid" /> *@

                <div class="mb-3">
                    <label for="deliveryManId">@AppResource.Labels.Carrier</label>
                    <select id="deliveryManId" name="DeliveryManId" class="form-control">
                        <option value="">@AppResource.Labels.SelectCarrier ?? "Select Carrier"</option>
                        <span asp-validation-for="CarrierId" class="text-danger"></span>
                    </select>
                </div>


                <div class="d-flex">
                    <button id="btnMakeReady" type="button" class="btn btn-gradient-primary me-2">@AppResource.Labels.MarkReady</button>
                    <a asp-action="List" class="btn btn-outline-secondary">@AppResource.Labels.Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>




@section Scripts
{
    @await Html.PartialAsync("_AlertMessage")

    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css" />
    <!-- plugins:js -->
